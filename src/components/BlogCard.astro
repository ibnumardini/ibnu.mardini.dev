---
interface Props {
	id: string;
	title: string;
	date: Date;
	description: string;
	language: 'en' | 'id';
}

const { id, title, date, description, language } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const languageLabel = { en: 'EN', id: 'ID' }[language];
---

<a href={`/blog/${id}`} class="group block border-l-2 border-slate-200 pl-4 py-2 transition-colors hover:border-accent dark:border-slate-800 dark:hover:border-accent">
	<div class="flex items-center gap-2">
		<p class="text-sm text-slate-500 dark:text-slate-400">{formattedDate}</p>
		<span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-300">
			{languageLabel}
		</span>
	</div>
	<h3 class="font-semibold group-hover:underline">{title}</h3>
	<p class="mt-1 text-sm text-slate-600 dark:text-slate-300">{description}</p>
</a>
