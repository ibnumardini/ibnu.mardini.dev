---
import { Image } from 'astro:assets';
import ClientRouter from 'astro/components/ClientRouter.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import SocialLinks from '../components/SocialLinks.astro';
import BackToTop from '../components/BackToTop.astro';
import DaisyModal from '../components/DaisyModal.astro';
import { profile } from '../data/profile';
import daisy from '../assets/daisy.jpg';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = profile.summary } = Astro.props;

const ogImage = new URL('/images/daisy.webp', Astro.site).href;
const canonicalURL = Astro.url.href;

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const navLinks = [
	{ href: '/about', label: 'About', active: path === '/about' },
	{ href: '/projects', label: 'Projects', active: path === '/projects' },
	{ href: '/blog', label: 'Blog', active: path === '/blog' || path.startsWith('/blog/') },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/png" href="/images/dark.png" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalURL} />
		<title>{title}</title>
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<ClientRouter />

		<script is:inline>
			function applyTheme() {
				const stored = localStorage.theme;
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (stored === 'dark' || (!stored && prefersDark)) {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
			}
			applyTheme();
			document.addEventListener('astro:after-swap', applyTheme);
		</script>
	</head>
	<body class="bg-white font-sans text-slate-900 transition-colors dark:bg-slate-950 dark:text-slate-100">
		<header
			class="sticky top-0 z-10 border-b border-slate-200/80 bg-white/70 backdrop-blur-lg dark:border-slate-800/80 dark:bg-slate-950/70"
		>
			<div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-6">
				<a href="/" class="flex items-center gap-2">
					<img src="/images/light.png" alt="ibnumardini logo" class="h-6 w-auto dark:hidden" />
					<img src="/images/dark.png" alt="ibnumardini logo" class="hidden h-6 w-auto dark:block" />
					<span class="hidden font-semibold sm:inline">ibnumardini</span>
				</a>
				<nav class="flex items-center gap-4 sm:gap-6">
					{
						navLinks.map((link) => (
							<a href={link.href} class:list={['text-sm hover:underline', { underline: link.active }]}>
								{link.label}
							</a>
						))
					}
					<ThemeToggle />
				</nav>
			</div>
		</header>
		<main class="mx-auto max-w-3xl px-6">
			<slot />
			<Image
				src={daisy}
				alt="A field of daisies"
				widths={[400, 800, 1200]}
				sizes="(min-width: 768px) 768px, 100vw"
				class="mt-10 mb-10 h-25 w-full rounded-lg object-cover opacity-90 saturate-50 transition-all hover:opacity-100 hover:saturate-100 dark:opacity-80 dark:hover:opacity-100"
			/>
		</main>
		<footer
			class="mx-auto flex max-w-3xl items-center justify-between px-6 py-10 text-sm text-slate-500 dark:text-slate-400"
		>
			<p>
				&copy; {new Date().getFullYear()} &middot; {profile.name} &middot;{' '}
				<button
					data-daisy-trigger
					class="cursor-pointer underline underline-offset-2 transition-colors hover:text-slate-900 dark:hover:text-white"
				>
					Daisy
				</button>
			</p>
			<SocialLinks size={18} />
		</footer>
		<BackToTop />
		<DaisyModal />
	</body>
</html>
