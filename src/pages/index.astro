---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { profile } from '../data/profile';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);

const pinnedProjects = profile.projects.filter((project) => project.pinned);
---

<Layout title={`${profile.name} - ${profile.title}`}>
	<section class="py-16">
		<h1 class="font-heading text-4xl font-bold sm:text-5xl">Wassup?</h1>
		<p class="mt-4 text-slate-600 dark:text-slate-300">
			Just a place where I share my thoughts and ideas about backend engineering, distributed
			systems, and whatever I'm working on. Feel free to browse around.
		</p>
		<p class="mt-4 text-slate-600 dark:text-slate-300">
			More details about me? Check out the{' '}
			<a href="/about" class="font-semibold text-slate-900 underline underline-offset-2 dark:text-white">about page</a>, or grab my{' '}
			<a href={profile.cvUrl} target="_blank" rel="noopener noreferrer" class="font-semibold text-slate-900 underline underline-offset-2 dark:text-white">CV</a>.
		</p>
		<div class="mt-6">
			<SocialLinks size={22} />
		</div>
	</section>

	<section id="projects" class="py-10">
		<div class="flex items-baseline justify-between">
			<h2 class="font-heading text-xl font-semibold">Featured Projects</h2>
			<a href="/projects" class="text-sm hover:underline">View all &rarr;</a>
		</div>
		<div class="mt-4 grid gap-4 sm:grid-cols-2">
			{pinnedProjects.map((project) => <ProjectCard {...project} />)}
		</div>
	</section>

	<section class="py-10">
		<div class="flex items-baseline justify-between">
			<h2 class="font-heading text-xl font-semibold">Recent Post</h2>
			<a href="/blog" class="text-sm hover:underline">View all &rarr;</a>
		</div>
		<div class="mt-2 divide-y divide-slate-200 dark:divide-slate-800">
			{posts.map((post) => (
				<BlogCard id={post.id} title={post.data.title} date={post.data.date} description={post.data.description} />
			))}
		</div>
	</section>

	<blockquote class="rounded-r-md border-l-2 border-slate-200 bg-slate-50 py-2 pl-4 font-mono text-sm text-slate-500 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-400">
		if err := beNice(); err != nil {'{'} beKind() {'}'}
	</blockquote>
</Layout>
