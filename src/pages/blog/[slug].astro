---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { profile } from '../../data/profile';
import { formatBlogDate, blogLanguageLabel } from '../../lib/blog';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
	return posts.map((post, index) => ({
		params: { slug: post.id },
		props: { post, newerPost: posts[index - 1], olderPost: posts[index + 1] },
	}));
}

interface Props {
	post: CollectionEntry<'blog'>;
	newerPost?: CollectionEntry<'blog'>;
	olderPost?: CollectionEntry<'blog'>;
}

const { post, newerPost, olderPost } = Astro.props;
const { Content } = await render(post);

const formattedDate = formatBlogDate(post.data.date);
const languageLabel = blogLanguageLabel(post.data.language);
---

<Layout title={`${post.data.title} - ${profile.name}`} description={post.data.description}>
	<article class="py-10">
		<a href="/blog" class="text-sm hover:underline">&larr; Back to blog</a>
		<h1 class="mt-4 text-2xl font-bold">{post.data.title}</h1>
		<div class="mt-1 flex items-center gap-2">
			<p class="text-sm text-slate-500 dark:text-slate-400">{formattedDate}</p>
			<span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-300">
				{languageLabel}
			</span>
		</div>
		<div class="prose prose-slate dark:prose-invert mt-6 max-w-none">
			<Content />
		</div>
		{
			(olderPost || newerPost) && (
				<nav class="mt-10 flex items-center justify-between gap-4 border-t border-slate-200 pt-6 dark:border-slate-800">
					{olderPost ? (
						<a href={`/blog/${olderPost.id}`} class="max-w-[45%] text-sm hover:underline">
							&larr; {olderPost.data.title}
						</a>
					) : (
						<span />
					)}
					{newerPost && (
						<a href={`/blog/${newerPost.id}`} class="max-w-[45%] text-right text-sm hover:underline">
							{newerPost.data.title} &rarr;
						</a>
					)}
				</nav>
			)
		}
	</article>
</Layout>
