---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { profile } from '../../data/profile';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title={`Blog - ${profile.name}`} description="Writing on backend engineering and distributed systems.">
	<section class="py-10">
		<h1 class="text-2xl font-bold">Blog</h1>
		<div class="mt-6 space-y-4">
			{posts.map((post) => (
				<BlogCard id={post.id} title={post.data.title} date={post.data.date} description={post.data.description} language={post.data.language} />
			))}
		</div>
	</section>
</Layout>
