---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import EducationItem from '../components/EducationItem.astro';
import CertificationItem from '../components/CertificationItem.astro';
import { profile } from '../data/profile';
import avatar from '../assets/avatar.png';
---

<Layout title={`About - ${profile.name}`} description={profile.summary}>
	<section class="py-16 text-center">
		<Image
			src={avatar}
			alt={profile.name}
			width={128}
			height={128}
			class="mx-auto h-24 w-24 rounded-full object-cover sm:h-32 sm:w-32"
		/>
		<h1 class="font-heading mt-4 text-3xl font-bold sm:text-4xl">{profile.name}</h1>
		<p class="mt-2 text-lg text-slate-600 dark:text-slate-300">{profile.title}</p>
		<p class="mt-1 flex items-center justify-center gap-1.5 text-sm text-slate-500 dark:text-slate-400">
			{profile.location}
			<Icon name="circle-flags:id" size={16} />
		</p>
		<p class="mx-auto mt-6 max-w-2xl text-left text-slate-600 dark:text-slate-300">{profile.summary}</p>
	</section>

	<section class="py-10">
		<h2 class="font-heading flex items-center gap-2 text-xl font-semibold">
			<Icon name="tabler:bolt" size={20} /> Skills
		</h2>
		<div class="mt-4 grid gap-4 sm:grid-cols-2">
			{profile.skills.map((group) => (
				<div>
					<h3 class="text-sm font-medium text-slate-500 dark:text-slate-400">{group.category}</h3>
					<p class="mt-1 text-sm text-slate-700 dark:text-slate-300">{group.items.join(', ')}</p>
				</div>
			))}
		</div>
	</section>

	<section class="py-10">
		<h2 class="font-heading flex items-center gap-2 text-xl font-semibold">
			<Icon name="tabler:briefcase" size={20} /> Experiences
		</h2>
		<div id="experience-wrapper" class="relative mt-4">
			<div id="experience-items" class="space-y-6 overflow-hidden transition-all duration-500 ease-in-out" style="max-height: 500px;">
				{profile.experience.map((entry) => <ExperienceItem {...entry} />)}
			</div>
			<div id="experience-gradient" class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-linear-to-t from-white to-transparent dark:from-slate-950"></div>
		<button
			id="experience-toggle"
			class="relative z-10 mx-auto mt-4 flex items-center gap-1 text-sm font-medium text-slate-500 transition-colors hover:text-slate-800 dark:text-slate-400 dark:hover:text-white"
		>
			<span id="experience-toggle-text">Show more</span>
			<Icon id="experience-toggle-icon" name="tabler:chevron-down" size={16} class="transition-transform duration-300" />
		</button>
		</div>
	</section>

	<script>
		function setupExperienceToggle() {
			const wrapper = document.getElementById('experience-wrapper');
			const items = document.getElementById('experience-items');
			const toggle = document.getElementById('experience-toggle');
			const toggleText = document.getElementById('experience-toggle-text');
			const toggleIcon = document.getElementById('experience-toggle-icon') as HTMLElement | null;
			const gradient = document.getElementById('experience-gradient');
			if (!items || !toggle || !gradient || !wrapper || !toggleText || !toggleIcon) return;

			const children = Array.from(items.children) as HTMLElement[];
			const itemHeights = children.map((el) => el.getBoundingClientRect().height);
			const gap = 24;
			const collapsedHeight = itemHeights.slice(0, 3).reduce((a, b) => a + b, 0) + gap * 2;
			const expandedHeight = itemHeights.reduce((a, b) => a + b, 0) + gap * (children.length - 1);
			items.style.maxHeight = collapsedHeight + 'px';
			let expanded = false;

			toggle.onclick = () => {
				expanded = !expanded;
				items.style.maxHeight = expanded ? expandedHeight + 40 + 'px' : collapsedHeight + 'px';
				gradient.classList.toggle('hidden', expanded);
				toggleText.textContent = expanded ? 'Show less' : 'Show more';
				toggleIcon.style.transform = expanded ? 'rotate(180deg)' : '';
			};
		}

		function setupCertToggle() {
			const certWrapper = document.getElementById('cert-wrapper');
			const certItems = document.getElementById('cert-items');
			const certToggle = document.getElementById('cert-toggle');
			const certToggleText = document.getElementById('cert-toggle-text');
			const certToggleIcon = document.getElementById('cert-toggle-icon') as HTMLElement | null;
			const certGradient = document.getElementById('cert-gradient');
			if (!certItems || !certToggle || !certGradient || !certWrapper || !certToggleText || !certToggleIcon) return;

			const children = Array.from(certItems.children) as HTMLElement[];
			const itemHeights = children.map((el) => el.getBoundingClientRect().height);
			const gap = 16;
			const collapsedHeight = itemHeights.slice(0, 5).reduce((a, b) => a + b, 0) + gap * 4;
			const expandedHeight = itemHeights.reduce((a, b) => a + b, 0) + gap * (children.length - 1);
			certItems.style.maxHeight = collapsedHeight + 'px';
			let expanded = false;

			certToggle.onclick = () => {
				expanded = !expanded;
				certItems.style.maxHeight = expanded ? expandedHeight + 40 + 'px' : collapsedHeight + 'px';
				certGradient.classList.toggle('hidden', expanded);
				certToggleText.textContent = expanded ? 'Show less' : 'Show more';
				certToggleIcon.style.transform = expanded ? 'rotate(180deg)' : '';
			};
		}

		document.addEventListener('astro:page-load', () => {
			setupExperienceToggle();
			setupCertToggle();
		});
	</script>

	<section class="py-10">
		<h2 class="font-heading flex items-center gap-2 text-xl font-semibold">
			<Icon name="tabler:school" size={20} /> Educations
		</h2>
		<div class="mt-4 space-y-6">
			{profile.education.map((entry) => <EducationItem {...entry} />)}
		</div>
	</section>

	<section class="py-10">
		<h2 class="font-heading flex items-center gap-2 text-xl font-semibold">
			<Icon name="tabler:certificate" size={20} /> Certifications
		</h2>
		<div id="cert-wrapper" class="relative mt-4">
			<div id="cert-items" class="space-y-4 overflow-hidden transition-all duration-500 ease-in-out" style="max-height: 300px;">
				{profile.certifications.map((cert) => <CertificationItem {...cert} />).reverse()}
			</div>
			<div id="cert-gradient" class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-linear-to-t from-white to-transparent dark:from-slate-950"></div>
		<button
			id="cert-toggle"
			class="relative z-10 mx-auto mt-4 flex items-center gap-1 text-sm font-medium text-slate-500 transition-colors hover:text-slate-800 dark:text-slate-400 dark:hover:text-white"
		>
			<span id="cert-toggle-text">Show more</span>
			<Icon id="cert-toggle-icon" name="tabler:chevron-down" size={16} class="transition-transform duration-300" />
		</button>
		</div>
	</section>

	<section class="py-10 text-center">
		<a
			href={profile.cvUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="inline-flex items-center gap-2 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-slate-700 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200"
		>
			<Icon name="tabler:printer" size={18} />
			Print CV
		</a>
	</section>
</Layout>
