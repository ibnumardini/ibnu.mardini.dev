---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import EducationItem from '../components/EducationItem.astro';
import CertificationItem from '../components/CertificationItem.astro';
import { profile } from '../data/profile';
---

<Layout title={`About - ${profile.name}`} description={profile.summary}>
	<section class="py-16 text-center">
		<img
			src="/images/avatar.png"
			alt={profile.name}
			class="mx-auto h-24 w-24 rounded-full object-cover sm:h-32 sm:w-32"
		/>
		<h1 class="font-heading mt-4 text-3xl font-bold sm:text-4xl">{profile.name}</h1>
		<p class="mt-2 text-lg text-slate-600 dark:text-slate-300">{profile.title}</p>
		<p class="mt-1 flex items-center justify-center gap-1.5 text-sm text-slate-500 dark:text-slate-400">
			{profile.location}
			<Icon name="circle-flags:id" size={16} />
		</p>
		<p class="mx-auto mt-6 max-w-2xl text-left text-slate-600 dark:text-slate-300">{profile.summary}</p>
	</section>

	<section class="py-10">
		<h2 class="font-heading text-xl font-semibold">Skills</h2>
		<div class="mt-4 grid gap-4 sm:grid-cols-2">
			{profile.skills.map((group) => (
				<div>
					<h3 class="text-sm font-medium text-slate-500 dark:text-slate-400">{group.category}</h3>
					<p class="mt-1 text-sm text-slate-700 dark:text-slate-300">{group.items.join(', ')}</p>
				</div>
			))}
		</div>
	</section>

	<section class="py-10">
		<h2 class="font-heading text-xl font-semibold">Experience</h2>
		<div class="mt-4 space-y-6">
			{profile.experience.map((entry) => <ExperienceItem {...entry} />)}
		</div>
	</section>

	<section class="py-10">
		<h2 class="font-heading text-xl font-semibold">Education</h2>
		<div class="mt-4 space-y-6">
			{profile.education.map((entry) => <EducationItem {...entry} />)}
		</div>
	</section>

	<section class="py-10">
		<h2 class="font-heading text-xl font-semibold">Certifications</h2>
		<div class="mt-4 space-y-4">
			{profile.certifications.map((cert) => <CertificationItem {...cert} />)}
		</div>
		<p class="mt-4 text-sm text-slate-500 dark:text-slate-400">
			Full list available on{' '}
			<a href="https://linkedin.com/in/ibnumardini" target="_blank" rel="noopener noreferrer" class="font-semibold text-slate-900 underline underline-offset-2 dark:text-white">
				LinkedIn
			</a>.
		</p>
	</section>
</Layout>
